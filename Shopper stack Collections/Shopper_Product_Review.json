	"item": [
		{
			"name": "Add a review to delivered product",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "68c98e7a-7991-44a0-a1cd-e7f753595e3d",
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"pm.test(\"Status Message : OK\", function () {\r",
							"    pm.response.to.have.status(\"OK\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1500ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
							"});\r",
							"\r",
							"pm.environment.set(\"reviewId\", pm.response.json().data.reviewId);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "5002773b-428a-4540-a24b-8a700871d4e3",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"dateTime\": \"2025-12-02T19:15:03.496Z\",\r\n  \"description\": \"Product is good\",\r\n  \"heading\": \"good\",\r\n  \"rating\": 4,\r\n  \"shopperId\": {{alternate_user_id}},\r\n  \"shopperName\": \"{{firstname}}\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseurl}}/reviews?productId={{productId}}",
