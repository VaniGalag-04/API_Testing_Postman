{
	"info": {
		"_postman_id": "ae70dd41-f27d-430a-9e71-7a91b0833200",
		"name": "Shopper Bank Cards",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "Creates the new card for a given bank",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "cca9e670-a652-43a2-a532-1e7ca8c997f3",
						"exec": [
							"pm.test(\"Status code is 201\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"pm.test(\"Status Message is : Created\", function () {\r",
							"    pm.response.to.have.status(\"Created\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1000ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
							"});\r",
							"\r",
							"pm.environment.set(\"credit_card_num\", pm.response.json().data.number);\r",
							"pm.environment.set(\"credit_card_cvv\", pm.response.json().data.cvv);\r",
							"pm.environment.set(\"credit_card_pin\", pm.response.json().data.pin);\r",
							"pm.environment.set(\"credit_card_expDate\", pm.response.json().data.expiryDate);\r",
							"pm.environment.set(\"credit_card_Id\", pm.response.json().data.cardId);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "f91f524e-55a0-4ce8-807c-b88b0ce63b9a",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseurl}}/cards?bankName={{bankName}}&cardType=CREDIT&email={{alternate_email}}&name={{firstname}}&shopperId={{alternate_user_id}}",
					"host": [
						"{{baseurl}}"
					],
					"path": [
						"cards"
					],
					"query": [
						{
							"key": "bankName",
							"value": "{{bankName}}"
						},
						{
							"key": "cardType",
							"value": "CREDIT"
						},
						{
							"key": "email",
							"value": "{{alternate_email}}"
						},
						{
							"key": "name",
							"value": "{{firstname}}"
						},
						{
							"key": "shopperId",
							"value": "{{alternate_user_id}}"
						}
					]
				}
			},
			"response": []
		},
