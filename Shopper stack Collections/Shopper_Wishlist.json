{
	"info": {
		"_postman_id": "e2338637-32bb-4060-b5ba-bb46104911e9",
		"name": "Shopper Wishlist",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "Get all products from wishlist",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "c6f95bf4-35bb-413b-b42f-f49f61edcb8b",
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"pm.test(\"Status Message : OK\", function () {\r",
							"    pm.response.to.have.status(\"OK\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1500ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "7d10fc88-594d-42aa-ac47-8d11e3c79391",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "GET",
				"header": [],
				"url": "{{baseurl}}/shoppers/{{alternate_user_id}}/wishlist"
			},
			"response": []
		},
		{
			"name": "Add product to wishlist",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "6fbc7698-e1d0-41fe-9dcc-6b00c9ca7657",
						"exec": [
							"pm.test(\"Status code is 201\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"pm.test(\"Status Message : Created\", function () {\r",
							"    pm.response.to.have.status(\"Created\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1500ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "8878efec-45c4-4dac-8b9a-3df26ed01c61",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"productId\": {{productId}},\r\n  \"quantity\": 1\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": "{{baseurl}}/shoppers/{{alternate_user_id}}/wishlist"
			},
			"response": []
		},
		{
			"name": "Delete product from wishlist",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "26dd6571-00de-4e0c-bafd-aa3e800fe3da",
						"exec": [
							"pm.test(\"Status code is 204\", function () {\r",
							"    pm.response.to.have.status(204);\r",
							"});\r",
							"pm.test(\"Status Message : No Content\", function () {\r",
							"    pm.response.to.have.status(\"No Content\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1500ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "c90ece2c-2de4-464c-98fc-f418f9296041",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "DELETE",
				"header": [],
				"url": "{{baseurl}}/shoppers/{{alternate_user_id}}/wishlist/{{productId}}"
			},
			"response": []
		}
	],
	"auth": {
		"type": "bearer",
