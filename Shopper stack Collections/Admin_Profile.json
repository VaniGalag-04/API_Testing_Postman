					"mode": "raw",
					"raw": "{\r\n  \"city\": \"{{city}}\",\r\n  \"country\": \"{{country}}\",\r\n  \"email\": \"{{$randomEmail}}\",\r\n  \"firstName\": \"Admin\",\r\n  \"lastName\": \"User\",\r\n  \"gender\": \"MALE\",\r\n  \"password\": \"{{admin_passwd}}\",\r\n  \"phone\": \"{{admin_phone}}\",\r\n  \"state\": \"{{state}}\",\r\n  \"street\": \"street\",\r\n  \"zipCode\": \"560001\",\r\n  \"role\": \"ADMIN\",\r\n  \"createdOn\": \"2025-01-01T10:00:00.000Z\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": "{{baseurl}}/admin"
			},
