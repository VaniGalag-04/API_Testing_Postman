	"item": [
		{
			"name": "Register as Admin",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "b7a5af72-6484-4362-83fd-9befd9677fec",
						"exec": [
							"pm.test(\"Status code is 201\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"pm.test(\"Status Message is : Created\", function () {\r",
							"    pm.response.to.have.status(\"Created\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1500ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
							"});\r",
							"\r",
							"var jsonData = pm.response.json()\r",
							"pm.environment.set(\"admin_email\", jsonData.data.email);\r",
							"pm.environment.set(\"admin_id\", jsonData.data.userId);\r",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "5288d0b8-cbf4-4fbd-8330-22e1e347caf7",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "verifyUrl",
						"value": "",
						"type": "text",
						"disabled": true
