{
	"info": {
		"_postman_id": "fb14c57b-cdab-4279-ae75-1eb65241cdb3",
		"name": "Merchant Product Review",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "Get all the reviews of a product",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "8c93dffc-29eb-43d1-8f96-05d9723fc7c4",
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"pm.test(\"Status message : OK\", function () {\r",
							"    pm.response.to.have.status(\"OK\");\r",
							"});\r",
							"pm.test(\"Response time is less than 1500ms\", function () {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"id": "c1520683-55d3-4547-bd9e-a9a73762bb03",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "GET",
				"header": [],
				"url": "{{baseurl}}/reviews/{{merchant_prodId}}"
			},
			"response": []
		},
